## Backend-only environment variables
#
# Do NOT use these in web/mobile apps. These are for servers, edge functions,
# background workers, or any trusted backend component only.
#
# Supabase
SUPABASE_URL=
#
# Use ONE of these depending on which key system your project uses:
# - Legacy elevated key: service_role (JWT)
# - New elevated key: sb_secret_...
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

