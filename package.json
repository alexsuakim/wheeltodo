{
  "name": "todo-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev -w apps/web",
    "dev:mobile": "npm run start -w apps/mobile",
    "lint": "npm run lint -w apps/web",
    "typecheck": "npm run typecheck -w packages/shared"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  }
}

